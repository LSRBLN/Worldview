# Kostenfrei weil Free-Tier / GitHub Student Pack
# Nur Free-Tier Tokens/Keys verwenden

# Optional: Für Cesium Helper createGooglePhotorealistic3DTileset()
VITE_CESIUM_ION_TOKEN=

# Optional: Direkter Google 3D Tiles Root-URL Fallback
VITE_GOOGLE_MAP_TILES_KEY=

# Optional: ArcGIS Static Basemap Tiles API Key (Free-Tier)
VITE_ARCGIS_API_KEY=

# Optional: ArcGIS Basemap Style (z. B. arcgis/light-gray, arcgis/imagery)
VITE_ARCGIS_BASEMAP_STYLE=arcgis/light-gray

# Optional: Umschaltung auf OpenSky Fallback Endpoint
VITE_ADSB_FALLBACK_URL=https://opendata.adsb.fi/api/v2/lat/24/lon/44/dist/220

# Optional: OpenSky API Basis-URL (Free REST)
VITE_OPENSKY_BASE_URL=https://opensky-network.org/api

# Optional: OpenSky Username für Basic Auth (höheres Rate-Limit)
# Registriere dich kostenlos auf https://opensky-network.org
# VITE_OPENSKY_USERNAME=dein-username

# Optional: OpenSky Password
# VITE_OPENSKY_PASSWORD=dein-passwort

# Optional: AISStream.io API Key (Free-Tier, WebSocket) - https://aisstream.io
VITE_AISSTREAM_API_KEY=

# Optional: AISStream WebSocket Endpoint (Free-Tier)
VITE_AIS_WS_URL=wss://stream.aisstream.io/v0/stream

# Optional: Legacy/Fallback Alias für AIS API Key
VITE_AIS_WS_API_KEY=
